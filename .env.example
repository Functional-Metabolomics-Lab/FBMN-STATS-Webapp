# ============================================================
# FBMN-STATS-GUIde — Environment Configuration Template
# Copy this file to .env and fill in your keys.
# ============================================================

# ----------------------------------------------------------
# OPTION 1 (Deployment / Primary): LiteLLM
# Used by default when deployed. Leave blank if not available.
# ----------------------------------------------------------
LITELLM_API_KEY=
LITELLM_API_BASE=

# ----------------------------------------------------------
# OPTION 2 (Local / Fallback): Google Gemini API
# Used automatically when LITELLM_API_KEY is not set.
# Get your free API key at: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------
GOOGLE_GEMINI_API_KEY=
